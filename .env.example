# =============================================================================
# SpAIder — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before running:
#   cp .env.example .env
#
# Generate secrets where instructed with the commands shown inline.
# =============================================================================

# -----------------------------------------------------------------------------
# Neo4j Graph Database
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=spaider-dev-2024

# -----------------------------------------------------------------------------
# Kafka Message Queue
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_INGEST=spaider.ingest.raw
KAFKA_TOPIC_DLQ=spaider.ingest.dlq
KAFKA_TOPIC_WORKFLOW_EVENTS=spaider.workflow.events
KAFKA_CONSUMER_GROUP=spaider-compressor-workers
KAFKA_REPLAY_CONSUMER_GROUP=spaider-replay-readers
KAFKA_AGENT_NAMESPACE=default

# -----------------------------------------------------------------------------
# Redis Cache & Session Store
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# PostgreSQL — Connector State & Secrets Store
# Used by the ConnectorScheduler and ConnectorRunner to persist run state,
# credentials, and cursor positions across restarts.
# MUST use the postgresql+asyncpg:// scheme — psycopg2 deadlocks in asyncio.
# The compose Postgres credentials default to these dev values; override
# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB (and this URL to match) for
# any non-local deployment.
# -----------------------------------------------------------------------------
POSTGRES_USER=spaider
POSTGRES_PASSWORD=spaider
POSTGRES_DB=spaider
POSTGRES_URL=postgresql+asyncpg://spaider:spaider@postgres:5432/spaider

# -----------------------------------------------------------------------------
# Connector Secret Encryption Key — AES-256-GCM Key Encryption Key (KEK)
# Used to envelope-encrypt connector credentials at rest in PostgreSQL.
# Generate a fresh key with:
#   python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# NEVER commit the real value. Leave blank to disable connector credential encryption.
# -----------------------------------------------------------------------------
CONNECTOR_SECRET_KEY=

# -----------------------------------------------------------------------------
# ClickHouse Analytics
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=spaider
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=spaider-dev-2024

# -----------------------------------------------------------------------------
# LLM Provider (via LiteLLM)
# Supported providers: openai, anthropic, ollama, azure, groq, cohere
# For Ollama: set LLM_BASE_URL=http://ollama:11434 and LLM_PROVIDER=ollama
# For Azure:  set LLM_BASE_URL=https://<deployment>.openai.azure.com
#
# Default: gpt-4o. Measurement on bench-hotpotqa-clean (POSITIONING.md
# learnings ledger) shows gpt-4o reliably cracks multi-hop bridge
# questions and numerical comparisons that gpt-4o-mini cannot. The
# trade-off is ~10x higher per-query token cost. For cost-sensitive
# deployments, switch to LLM_MODEL=gpt-4o-mini — most of SpAIder's
# pipeline still works well, only the hardest multi-hop questions
# regress.
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# Exponential-backoff retry around every litellm.acompletion call.
# Default values are tuned so that the gpt-4o default above survives
# OpenAI's per-minute token throughput limits under burst load.
# Set LITELLM_RETRY_MAX_ATTEMPTS=1 to disable retry entirely.
LITELLM_RETRY_MAX_ATTEMPTS=5
LITELLM_RETRY_BASE_DELAY=1.0

# -----------------------------------------------------------------------------
# Embeddings
#
# Default: OpenAI text-embedding-3-small (1536-dim, ~10 ms per call,
# ~$0.02 per 1M tokens). Recommended for any production-scale ingest.
#
# Local alternative: Ollama embeddinggemma:300m (768-dim, free, ~500-1000 ms
# per call on Mac CPU). Suitable for offline / no-API-key dev work.
#
# EMBEDDING_DIMENSIONS MUST match your chosen model's actual output:
#   text-embedding-3-small         → 1536
#   text-embedding-3-large         → 3072
#   embeddinggemma:300m            → 768
#   all-MiniLM-L6-v2               → 384
#
# Mixing dimensions in a single agent's graph corrupts the Neo4j vector
# index — switch only on a fresh agent (rotate the agent or re-seed). The
# backend logs a startup ERROR if it detects pre-existing embeddings
# whose dimensionality differs from EMBEDDING_DIMENSIONS.
#
# To switch to local Ollama, comment out the OpenAI block below and
# uncomment the Ollama block:
# -----------------------------------------------------------------------------

# OpenAI (default, recommended for production)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSIONS=1536

# Ollama (local, free; uncomment + comment OpenAI block to switch)
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=embeddinggemma:300m
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=http://host.docker.internal:11434
# EMBEDDING_DIMENSIONS=768

# -----------------------------------------------------------------------------
# Auth — JWT & API Keys
# JWT_SECRET: sign with a strong random string (>=32 chars)
#   Generate: python -c "import secrets; print(secrets.token_hex(32))"
# API keys are stored as SHA-256 hashes in Redis.
# Issue keys via: POST /api/v1/agents  (returns sk-... key on creation)
# Rotate keys via: POST /api/v1/agents/{id}/rotate-key
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# -----------------------------------------------------------------------------
# Kong API Gateway
# -----------------------------------------------------------------------------
KONG_ADMIN_URL=http://kong:8001

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# -----------------------------------------------------------------------------
# MCP Server (SpAIder-as-MCP-server)
# -----------------------------------------------------------------------------
# Serves the Streamable HTTP MCP endpoint at /api/v1/mcp so any MCP-capable LLM
# client (Claude Code, Cursor, OpenCode, custom agents, ...) can use SpAIder as durable
# memory. Set to "false" to skip mounting the MCP routes entirely — useful
# for deployments where ops policy requires REST-only access. The routes
# are auth-gated whether enabled or not.
SPAIDER_MCP_ENABLED=true

# -----------------------------------------------------------------------------
# Airflow REST API — for the on-demand graph_maintenance trigger
# (POST /api/v1/system/consolidate).
#
# When AIRFLOW_BASE_URL is empty, the consolidate endpoint returns 503 with
# a pointer to the CLI fallback. To enable on-demand triggering, bring up
# the Airflow stack (``make airflow-up``) and set:
#   AIRFLOW_BASE_URL=http://spaider-airflow-webserver:8080
# Default username / password match docker-compose.airflow.yml.
# -----------------------------------------------------------------------------
AIRFLOW_BASE_URL=
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=spaider-airflow
AIRFLOW_CONSOLIDATE_DAG_ID=spaider_graph_maintenance

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=false
