# Neo4j (use localhost for direct dev outside Docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=spaider-dev-2024

# Kafka (use localhost:29092 for direct dev outside Docker)
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC_INGEST=spaider.ingest.raw
KAFKA_CONSUMER_GROUP=spaider-compressor-workers

# Redis (use localhost for direct dev outside Docker)
REDIS_URL=redis://localhost:6379/0

# LLM — local Ollama (default, zero external dependencies)
LLM_PROVIDER=ollama
LLM_MODEL=ollama/qwen3.5:9b
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=  # your provider API key (leave empty for Ollama)
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# LLM — OpenAI alternative (comment out Ollama block above, uncomment below)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=
# LLM_API_KEY=sk-your-key-here

# Embeddings: local Ollama (default, matches the Ollama LLM block above so the
# whole stack runs with zero external dependencies). Pull the model first:
#   ollama pull embeddinggemma:300m
# EMBEDDING_DIMENSIONS must match the model's output (embeddinggemma = 768) and
# must be set BEFORE the first ingest (it sizes the Neo4j vector index).
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=embeddinggemma:300m
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_DIMENSIONS=768

# Embeddings: OpenAI alternative (comment out the Ollama block above, uncomment below)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=sk-your-key-here
# EMBEDDING_BASE_URL=
# EMBEDDING_DIMENSIONS=1536

# Auth
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Kong
KONG_ADMIN_URL=http://localhost:8001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Airflow
AIRFLOW__CORE__FERNET_KEY=your-fernet-key
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
